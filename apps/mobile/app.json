{
  "expo": {
    "name": "Watchtower",
    "slug": "watchtower",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Watchtower uses your location to prefill where your weather watches apply."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.watchtower.app"
    },
    "android": {
      "package": "com.watchtower.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "https://watchtower-web-nu.vercel.app",
      "eas": {
        "projectId": "47d0fff9-6f16-4b05-b6b2-054b03e6c106"
      }
    },
    "owner": "moseley"
  }
}
