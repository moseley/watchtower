# ---------------------------------------------------------------------------
# Watchtower environment variables (TEMPLATE — safe to commit).
#
# Copy this file to `.env` and fill in real values there. `.env` is git-ignored.
#   pwsh:   Copy-Item .env.example .env
# ---------------------------------------------------------------------------

# --- Database: Neon Postgres (provisioned via Vercel → Storage) -------------
# Find both strings in Neon's "Connect" widget
# (Vercel → your project → Storage → the database → Connect):
#
#   DATABASE_URL          = the POOLED string. Its host contains "-pooler".
#                           Used by the app/serverless at runtime.
#   DATABASE_URL_UNPOOLED = the direct (non-pooling) string. No "-pooler".
#                           Used by Prisma for migrations. This is the name
#                           Vercel's Neon integration injects automatically.
#
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# --- Cron auth (added in Phase 1) ------------------------------------------
# Random secret so only Vercel Cron can hit the poll/match route.
# Generate:  openssl rand -hex 32
# CRON_SECRET=
