# dependencies
node_modules/

# builds / caches
.next/
out/
dist/
build/
.turbo/
.expo/
web-build/

# generated native projects (created by `expo prebuild`)
apps/mobile/ios/
apps/mobile/android/

# env / secrets — real values are git-ignored; only .env.example is committed
.env
.env.*
!.env.example

# Firebase service-account keys (SECRET — never commit).
# NOTE: google-services.json is safe to commit and is intentionally NOT ignored.
*firebase-adminsdk*.json
*service-account*.json
google-service-account*.json

# logs
*.log
npm-debug.log*

# os / editor
.DS_Store
Thumbs.db
.idea/
